{
  "displayName": "DAISY Pipeline",
  "name": "pipeline-ui",
  "description": "User interface for the DAISY Pipeline",
  "version": "1.11.0",
  "main": "./out/main/index.js",
  "devTempBuildFolder": "./out",
  "devServer": "http://localhost:4927",
  "author": {
    "name": "DAISY Consortium",
    "email": "daisy-pipeline@mail.daisy.org"
  },
  "contributors": [
    {
      "name": "Marisa DeMeglio",
      "email": "marisa.demeglio@gmail.com"
    },
    {
      "name": "Nicolas Pavie",
      "email": "pavie.nicolas@gmail.com"
    },
    {
      "name": "Bert Frees",
      "email": "bertfrees@gmail.com"
    }
  ],
  "license": "MIT",
  "scripts": {
    "prebuild": "yarn r predev",
    "build": "cross-env NODE_ENV=production electron-vite build",
    "postbuild": "node ./bin/modules/postbuild/index.js",
    "clean:dev": "rimraf out",
    "predev": "yarn r clean:dev pipeline:install",
    "dev": "electron-vite dev",
    "pipeline:install": "node ./bin/modules/prebuild/pipeline.js",
    "pipeline:refresh": "node ./bin/modules/prebuild/pipeline.js --refresh",
    "predist": "yarn build",
    "dist": "./node_modules/.bin/electron-builder --publish never",
    "predist-test:mac": "cross-env LOG_LEVEL=debug yarn build",
    "dist-test:mac": "SKIP_NOTARIZATION=true ./node_modules/.bin/electron-builder --publish never --mac -c.mac.identity=null",
    "predist-test:win": "cross-env LOG_LEVEL=debug yarn build",
    "dist-test:win": "./node_modules/.bin/electron-builder --publish never --win",
    "prerelease": "yarn build",
    "release": "./node_modules/.bin/electron-builder --publish always",
    "clean": "rimraf dist",
    "prepare": "husky install",
    "r": "yarn run-s"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.1",
    "@tanstack/react-query": "^4.2.1",
    "@xmldom/xmldom": "^0.8.6",
    "chardet": "^1.5.1",
    "decompress": "^4.2.1",
    "electron-log": "^5.3.4",
    "electron-updater": "^6.3.9",
    "fflate": "^0.8.2",
    "lucide-react": "^0.473.0",
    "node-fetch": "^3.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^8.0.3",
    "react-router-dom": "^6.3.0",
    "react-tabs": "^5.1.0",
    "remark-gfm": "^3.0.1",
    "sax": "^1.4.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.3",
    "@commitlint/config-conventional": "^17.0.3",
    "@electron/notarize": "^2.5.0",
    "@types/decompress": "^4.2.4",
    "@types/node": "^18.7.23",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^5.33.1",
    "@typescript-eslint/parser": "^5.33.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "electron": "38.2.0",
    "electron-builder": "24.7.0",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^8.22.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "sass": "^1.54.4",
    "typescript": "^4.7.4",
    "typescript-plugin-css-modules": "^3.4.0",
    "vite": "^8.0.3"
  },
  "eslintIgnore": [
    "dist"
  ]
}
