{
  "displayName": "DAISY Pipeline",
  "name": "pipeline-ui",
  "description": "User interface for the DAISY Pipeline",
  "version": "1.11.0",
  "main": "./out/main/index.js",
  "devTempBuildFolder": "./out",
  "devServer": "http://localhost:4927",
  "repository": {
    "type": "git",
    "url": "https://github.com/daisy/pipeline-ui.git"
  },
  "author": {
    "name": "DAISY Consortium",
    "email": "daisy-pipeline@mail.daisy.org"
  },
  "contributors": [
    {
      "name": "Marisa DeMeglio",
      "email": "marisa.demeglio@gmail.com"
    },
    {
      "name": "Nicolas Pavie",
      "email": "pavie.nicolas@gmail.com"
    },
    {
      "name": "Bert Frees",
      "email": "bertfrees@gmail.com"
    }
  ],
  "license": "MIT",
  "scripts": {
    "prebuild": "yarn r predev",
    "build": "cross-env NODE_ENV=production electron-vite build",
    "build:ci": "cross-env NODE_ENV=production electron-vite build",
    "postbuild": "node ./bin/modules/postbuild/index.js",
    "clean:dev": "rimraf out",
    "predev": "yarn r clean:dev pipeline:install",
    "dev": "electron-vite dev",
    "pipeline:install": "node ./bin/modules/prebuild/pipeline.js",
    "pipeline:refresh": "node ./bin/modules/prebuild/pipeline.js --refresh",
    "predist-debug:mac": "cross-env LOG_LEVEL=debug yarn build",
    "dist-debug:mac": "SKIP_NOTARIZATION=true ./node_modules/.bin/electron-builder --publish never --mac -c.mac.identity=null",
    "predist-debug:win": "cross-env LOG_LEVEL=debug yarn build",
    "dist-debug:win": "./node_modules/.bin/electron-builder --publish never --win",
    "predist-signed:mac": "yarn build",
    "dist-signed:mac": "./node_modules/.bin/electron-builder --publish never --mac",
    "predist-signed:win": "yarn build",
    "dist-signed:win": "./node_modules/.bin/electron-builder --publish never --win",
    "prerelease": "yarn build",
    "release": "./node_modules/.bin/electron-builder --publish always",
    "clean": "rimraf dist",
    "prepare": "husky install",
    "r": "yarn run-s"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^4.2.1",
    "@xmldom/xmldom": "^0.8.6",
    "chardet": "^2.1.1",
    "decompress": "^4.2.1",
    "electron-log": "^5.3.4",
    "electron-updater": "^6.3.9",
    "fflate": "^0.8.2",
    "lucide-react": "^1.7.0",
    "node-fetch": "^3.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "react-tabs": "^6.1.1",
    "remark-gfm": "^4.0.1",
    "sax": "^1.4.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.3",
    "@commitlint/config-conventional": "^17.0.3",
    "@electron/notarize": "^3.1.1",
    "@types/decompress": "^4.2.4",
    "@types/node": "^18.7.23",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^8.0.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sass": "^1.54.4",
    "typescript": "^6.0.2",
    "typescript-plugin-css-modules": "^3.4.0",
    "vite": "^8.0.3"
  }
}
